rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helpers
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        ("email" in request.auth.token && (request.auth.token.email == "kemalziyad4@gmail.com" || request.auth.token.email == "kemalziyad49@gmail.com")) ||
        (
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true
        )
      );
    }

    // ===============================================================
    // Collection Specific Matches
    // ===============================================================
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
    }

    match /userTasks/{userTaskId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /withdrawalRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /voiceRooms/{roomId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /voiceRooms/{roomId}/reactions/{reactionId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /rooms/{roomId}/chat/{chatId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /rooms/{roomId}/muted/{mutedId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /rooms/{roomId}/banned/{bannedId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /agentInvitations/{invitationId} {
      allow read, write: if isSignedIn();
    }

    match /hostApplications/{applicationId} {
      allow read, write: if isSignedIn();
    }

    match /inventories/{userId}/items/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    match /gifts/{giftId} {
      allow read, write: if isSignedIn();
    }

    match /coinTransactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    match /follows/{followId} {
      allow read, write: if isSignedIn();
    }

    match /roomActivities/{activityId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /fraud_reports/{reportId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    // ===============================================================
    // Global Catch-All (Default Deny)
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
