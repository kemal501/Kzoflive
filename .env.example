# Server configuration
PORT=3000
NODE_ENV=development

# Firebase Admin SDK credentials
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# Telegram Mini App Configuration
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ-1234abcd

# JWT Security
JWT_SECRET=super_secret_signing_key_for_oibb_earn_jwt_tokens

# NOWPayments Payouts Integration (Crypto USDT TRC20, BEP20, TON Payouts)
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY_HERE
NOWPAYMENTS_EMAIL=your-nowpayments-account-email@example.com
NOWPAYMENTS_PASSWORD=your-nowpayments-account-password

# Application URL
APP_URL=https://your-mini-app-domain.run.app

